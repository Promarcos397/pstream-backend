# --- SUPABASE (Identity & Sync) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
JWT_SECRET=p-stream-secret-keep-this-safe

# --- REDIS (Upstash/Global Cache) ---
# Format: redis://default:password@host:port
REDIS_URL=

# --- ISP PROXIES (Bypass Turnstile/IP Blocks) ---
ISP_PROXY_HOST=
ISP_PROXY_PORT=
ISP_PROXY_USERNAME=
ISP_PROXY_PASSWORD=
# Set to 'true' to enable proxying for initial token fetch
ISP_PROXY_URL=false

# --- SERVER ---
PORT=7860
